# База данных
DATABASE_URL="postgresql://turist:turist_dev_password@localhost:5432/turist_db?schema=public"

# JWT
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
